{
  "version": "4.0.0",
  "name": "Voice Remover Pro - ML Enhanced",

  "python": {
    "condaEnv": "music",
    "path": "",
    "fallbackPath": "python"
  },

  "modes": {
    "fast": {
      "label": "Fast",
      "description": "Быстрое разделение (Spleeter)",
      "model": "spleeter",
      "quality": "medium",
      "speed": "fast",
      "gpuRequired": false
    },
    "quality": {
      "label": "Quality",
      "description": "Высокое качество (Demucs v4 Hybrid Transformer)",
      "model": "demucs_ht",
      "quality": "high",
      "speed": "medium",
      "gpuRequired": false
    },
    "ultra": {
      "label": "Ultra",
      "description": "Максимальное качество (Ensemble Demucs + MDX-Net)",
      "model": "ensemble",
      "quality": "ultra",
      "speed": "slow",
      "gpuRequired": false
    },
    "modern": {
      "label": "Modern AI",
      "description": "Современные модели (Lalal.ai + MDX-Net 23c)",
      "model": "modern_ensemble",
      "quality": "ultra",
      "speed": "medium",
      "gpuRequired": true
    }
  },

  "defaultMode": "quality",

  "presets": {
    "default": {
      "label": "Default",
      "vocalsGain": 1.0,
      "drumsGain": 1.0,
      "bassGain": 1.0,
      "otherGain": 1.0
    },
    "pop": {
      "label": "Pop",
      "vocalsGain": 1.2,
      "drumsGain": 0.9,
      "bassGain": 1.1,
      "otherGain": 0.95
    },
    "rock": {
      "label": "Rock",
      "vocalsGain": 0.9,
      "drumsGain": 1.2,
      "bassGain": 1.0,
      "otherGain": 1.0
    },
    "rap": {
      "label": "Rap/Hip-Hop",
      "vocalsGain": 1.3,
      "drumsGain": 1.1,
      "bassGain": 1.2,
      "otherGain": 0.9
    },
    "jazz": {
      "label": "Jazz",
      "vocalsGain": 0.85,
      "drumsGain": 0.9,
      "bassGain": 1.0,
      "otherGain": 1.2
    },
    "classic": {
      "label": "Classic",
      "vocalsGain": 0.8,
      "drumsGain": 0.7,
      "bassGain": 0.9,
      "otherGain": 1.1
    },
    "electronic": {
      "label": "Electronic",
      "vocalsGain": 1.0,
      "drumsGain": 1.3,
      "bassGain": 1.2,
      "otherGain": 1.1
    },
    "acoustic": {
      "label": "Acoustic",
      "vocalsGain": 1.1,
      "drumsGain": 0.8,
      "bassGain": 0.9,
      "otherGain": 1.0
    }
  },

  "models": {
    "cacheDir": "",
    "autoDownload": true,
    "supportedModels": {
      "demucs": {
        "htdemucs_ft": {
          "name": "Demucs v4 Hybrid Transformer",
          "description": "Лучшая модель для 4-stem разделения",
          "stems": ["drums", "bass", "other", "vocals"],
          "size": "87MB",
          "quality": "high"
        },
        "htdemucs": {
          "name": "Demucs v4 Light",
          "description": "Быстрая версия для 4-stem",
          "stems": ["drums", "bass", "other", "vocals"],
          "size": "43MB",
          "quality": "medium"
        },
        "mdx_extra": {
          "name": "Demucs MDX Extra",
          "description": "Расширенная модель для сложных треков",
          "stems": ["drums", "bass", "other", "vocals"],
          "size": "120MB",
          "quality": "ultra"
        }
      },
      "mdxnet": {
        "UVR-MDX-NET-Inst_HQ_3": {
          "name": "MDX-Net Inst HQ 3",
          "description": "Высококачественное разделение инструментал/вокал",
          "stems": ["instrumental", "vocals"],
          "size": "150MB",
          "quality": "ultra"
        },
        "UVR_MDXNET_KARA_2": {
          "name": "MDX-Net Karaoke 2",
          "description": "Оптимизировано для караоке",
          "stems": ["instrumental", "vocals"],
          "size": "180MB",
          "quality": "ultra"
        }
      },
      "vrnet": {
        "1_HP-UVR": {
          "name": "VR Network HP",
          "description": "Высокопроизводительная модель",
          "stems": ["instrumental", "vocals"],
          "size": "200MB",
          "quality": "ultra"
        }
      },
      "spleeter": {
        "2stems": {
          "name": "Spleeter 2-stem",
          "description": "Быстрое разделение вокал/инструментал",
          "stems": ["vocals", "accompaniment"],
          "size": "25MB",
          "quality": "medium"
        },
        "4stems": {
          "name": "Spleeter 4-stem",
          "description": "Полное разделение на 4 стема",
          "stems": ["vocals", "drums", "bass", "piano"],
          "size": "45MB",
          "quality": "medium"
        }
      },
      "ensemble": {
        "modern_ensemble": {
          "name": "Modern Ensemble",
          "description": "Комбинация лучших современных моделей",
          "stems": ["vocals", "drums", "bass", "guitar", "piano", "other"],
          "size": "400MB+",
          "quality": "ultra"
        }
      }
    }
  },

  "processing": {
    "maxFileSize": 500,
    "maxConcurrentJobs": 2,
    "sampleRate": 44100,
    "outputFormat": "wav",
    "outputSubtype": "PCM_16"
  },

  "server": {
    "port": 8000,
    "host": "localhost",
    "cors": true,
    "maxUploadSize": "500mb"
  },

  "features": {
    "sourceSeparation": true,
    "fourStemSeparation": true,
    "bpmDetection": true,
    "keyDetection": true,
    "spectralAnalysis": true,
    "effects": true,
    "equalizer": true,
    "mixer": true,
    "export": true,
    "waveform": true,
    "spectrogram": true,
    "history": true
  }
}
